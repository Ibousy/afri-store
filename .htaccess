Options -Indexes
ServerSignature Off

# ── PHP Settings ──────────────────────────────────────────────
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value max_execution_time 60
    php_value memory_limit 128M
</IfModule>

# ── Forcer HTTPS (activer en production) ──────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Bloquer accès aux dossiers sensibles
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^logs/ - [F,L]
</IfModule>

# ── Sécurité fichiers sensibles ───────────────────────────────
<FilesMatch "\.(env|sql|log|md|git|yml|json|sh|bak)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

<FilesMatch "fichier\.env|\.env">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ── Headers de sécurité ───────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Compression Gzip ──────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>

# ── Cache navigateur ──────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png  "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css   "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
